# ========================================
# 统一 IP 地址配置（单一配置源）
# ========================================
# 修改这些 IP 后，运行以下命令同步到所有配置文件:
#   bash scripts/configure_ip.sh
#
# 同步范围: docker-compose.yml, .env, 场景 YAML, Java 默认值等

# 云端服务器 IP（本机，运行 Docker 服务的 GPU 服务器）
CLOUD_IP=192.168.1.123

# 边缘设备 IP（Jetson / 边缘推理设备，可为空）
EDGE_IP=192.168.0.1

# 端口配置（一般不需要修改）
CLOUD_API_PORT=8081
CLOUD_MQTT_PORT=1883
CLOUD_RTMP_PORT=1935
