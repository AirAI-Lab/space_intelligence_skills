# ============================================
# SkyEdge AI Cloud Platform 环境变量配置
# 复制为 .env 并修改配置后部署
# ============================================

# 版本号（镜像 tag）
VERSION=1.0.0

# ============================================
# 数据库配置
# ============================================
PG_PASSWORD=edge_pass

# ============================================
# Redis 配置
# ============================================
# Redis 默认无需密码，如需密码在 docker-compose 中添加

# ============================================
# MQTT 配置
# ============================================
EMQX_PASSWORD=admin123456

# ============================================
# API 认证密钥
# 第三方调用 REST API 需携带 X-API-Key header
# 生产部署务必修改为强密钥
# ============================================
API_KEY=edge-cloud-api-key-change-me

# ============================================
# 文件存储 (SeaweedFS S3)
# ============================================
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123456
S3_BUCKET=edge-cloud-files

# ============================================
# MLflow 配置
# ============================================
MLFLOW_TRACKING_URI=http://mlflow:5000

# ============================================
# 云端 API 外部访问地址
# 用于 Jetson/边缘设备下载模型和文件
# 修改为实际部署 IP 或域名
# ============================================
CLOUD_API_URL=http://192.168.0.103

# ============================================
# 云端推理场景配置 (可选)
# 留空则不自动启动推理，需手动 docker exec 启动
# ============================================
CONFIG_PATH=

# ============================================
# GPU 配置 (训练/推理服务)
# ============================================
CUDA_VISIBLE_DEVICES=0

# ============================================
# 镜像仓库 (可选)
# 推送到私有仓库时配置，留空则使用本地构建
# ============================================
REGISTRY=
