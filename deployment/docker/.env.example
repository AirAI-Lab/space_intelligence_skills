# edge_infer_cloud 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_NAME=edge_cloud
DB_USER=edge_user
DB_PASSWORD=edge_pass

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT 配置
MQTT_BROKER=tcp://emqx:1883
MQTT_CLIENT_ID=edge_cloud_backend
MQTT_USERNAME=
MQTT_PASSWORD=

# MinIO 配置
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# MLflow 配置
MLFLOW_TRACKING_URI=http://mlflow:5000

# 应用配置
SERVER_PORT=8080
LOG_LEVEL=INFO
