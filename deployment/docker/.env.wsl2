# ============================================
# edge_infer_cloud WSL2 环境变量覆盖
# 使用方式：deploy.sh 自动检测 WSL2 并加载此文件
# ============================================

# WSL2 数据卷路径
VOLUME_BASE_PATH=/docker/volumes/edge_cloud

# WSL2 外部资源路径（通过 /mnt/ 访问 Windows 磁盘）
EXTERNAL_DATA_PATH=/mnt/e/data

# WSL2 模型目录（Docker 无法跟随符号链接跨文件系统，需直接挂载 Windows 路径）
MODELS_PATH=/mnt/d/github/edge_infer_cloud/models

# WSL2 与 Windows 共享 IP
CLOUD_API_URL=http://192.168.0.103:8081
