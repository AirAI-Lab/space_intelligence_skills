{
  "name": "integration-test",
  "description": "端到端集成测试验证",
  "steps": [
    {
      "description": "检查 Docker 服务状态",
      "action": "docker-compose ps"
    },
    {
      "description": "验证后端 API",
      "action": "curl -s http://localhost:8081/actuator/health"
    },
    {
      "description": "验证前端服务",
      "action": "curl -s -o /dev/null -w '%{http_code}' http://localhost:3000"
    },
    {
      "description": "检查数据库表",
      "action": "docker exec edge_cloud_postgres psql -U edge_user -d edge_cloud -c '\\dt'"
    },
    {
      "description": "检查 MQTT 连接",
      "action": "docker logs edge_cloud_backend --grep MQTT | tail -5"
    }
  ],
  "tools": ["Bash"],
  "workingDirectory": "deployment/docker"
}
